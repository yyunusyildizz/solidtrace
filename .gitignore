# ========================
# 🔒 GÜVENLİK VE SIRLAR (EN KRİTİK)
# ========================
# Çevresel değişkenler
.env
.env.*
!.env.example

# Sertifikalar ve Anahtarlar (ASLA GİTMEMELİ)
*.pem
*.key
*.cert
*.pfx
*.p12
secrets/

# ========================
# 🗄️ VERİTABANI (Local DB)
# ========================
*.db
*.sqlite
*.sqlite3
backend/data/
# Not: backend/solidtrace.db zaten *.db kuralına takılacağı için ayrıca yazmaya gerek yok.

# ========================
# ⚙️ GENEL / İŞLETİM SİSTEMİ / IDE
# ========================
.DS_Store
Thumbs.db
ehthumbs.db
.idea/
.vscode/
*.swp
*.swo
*.exe
*.dll
*.so
*.dylib
*.log

# ========================
# 🦀 RUST (Agent)
# ========================
# Derleme çıktıları (Global olarak nerede olursa olsun target yoksayılır)
**/target/
**/*.pdb
**/*.rs.bk

# NOT: Cargo.lock dosyasını bilerek buraya eklemiyoruz.
# Bir "Uygulama" (Binary) geliştirdiğimiz için versiyonları kitlemek önemlidir.

# ========================
# 🐍 PYTHON (Backend)
# ========================
__pycache__/
*.py[cod]
*$py.class
**/venv/
**/.venv/
**/env/
.pytest_cache/
.coverage
htmlcov/
*.egg-info/

# Sadece requirements.txt dosyasına izin ver, diğer tüm txt dosyalarını yoksay
backend/*.txt
!backend/requirements.txt

# ========================
# ⚛️ NODE.JS / NEXT.JS (Frontend)
# ========================
**/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/dist/
frontend/.vercel/
frontend/*.tsbuildinfo

# Debug Logları
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*