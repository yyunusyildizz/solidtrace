# ============================================================
# SolidTrace Backend — Environment Variables
# ============================================================
# Bu dosyayı .env olarak kopyalayıp gerçek değerleri yazınız:
#   cp .env.example .env
# ============================================================

# --- Ortam ---
ENV=development

# --- JWT / Authentication ---
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_STRONG_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=solidtrace
JWT_AUDIENCE=solidtrace-panel

# --- Database ---
# SQLite (geliştirme):
# DATABASE_URL=sqlite:///./solidtrace.db
# PostgreSQL (production):
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost/solidtrace_db

# --- Frontend / CORS ---
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Agent Authentication ---
AGENT_KEY=CHANGE_ME_AGENT_SECRET_KEY
LEGACY_AGENT_AUTH=true
AGENT_SECRET_KEK=CHANGE_ME_GENERATE_FERNET_KEY
AGENT_MAX_SKEW_SECONDS=300
AGENT_NONCE_TTL_SECONDS=300
AGENT_RATE_LIMIT_PER_MINUTE=120
AGENT_IP_RATE_LIMIT_PER_MINUTE=60

# --- Command Signing ---
SOLIDTRACE_COMMAND_SIGNING_PRIVATE_KEY=CHANGE_ME_SIGNING_KEY

# --- API / Queue ---
API_RATE_LIMIT=200/minute
INGEST_MAX_BATCH=100
INGEST_MAX_DETAILS=4000
MIN_ALERT_SCORE=50
QUEUE_BATCH_SIZE=50
QUEUE_POLL_INTERVAL=1.0

# --- Noise Reduction ---
EVENT_DEDUP_WINDOW_SECONDS=20
EVENT_DEDUP_MAX_ITEMS=10000

# --- External Integrations (Optional) ---
SUPABASE_URL=
SUPABASE_KEY=
MB_API_URL=https://mb-api.abuse.ch/api/v1/
OTX_API_KEY=
GROQ_API_KEY=
BAZAAR_API_KEY=

# --- Tenant ---
DEFAULT_TENANT_ID=default_tenant

# --- Dev Bypass (ONLY for development!) ---
DEV_BYPASS_AGENT_AUTH=true
DEV_BYPASS_TENANT_ID=default_tenant
DEV_BYPASS_AGENT_ID=DESKTOP-DEV01
