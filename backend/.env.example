# ===== Core =====
ENV=development
DATABASE_URL=sqlite:///./solidtrace.db
JWT_SECRET_KEY=change-me-in-production
AGENT_API_KEY=change-me
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
MIN_ALERT_RISK=50

# ===== Optional Integrations =====
OTX_API_KEY=
BAZAAR_API_KEY=
GROQ_API_KEY=

# ===== Notification =====
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=
ALERT_EMAILS=
SLACK_WEBHOOK_URL=
WEBHOOK_URLS=

# ===== CEF / Syslog =====
SYSLOG_HOST=
SYSLOG_PORT=514
CEF_LOG_PATH=logs/solidtrace.cef
CEF_FILE_ENABLED=1

# ===== UEBA =====
UEBA_BASELINE_DIR=ueba_baselines
UEBA_LEARN_DAYS=7
UEBA_ANOMALY_THRESHOLD=70

# ===== Agent Release API =====
AGENT_VERSION=1.0.0
AGENT_BUILD_DATE=2026-01-01
AGENT_BINARY_DIR=releases
